# Python cache files
__pycache__/          # 忽略所有__pycache__文件夹
*.py[cod]             # 忽略所有Python编译文件(.pyc, .pyo, .pyd)
*$py.class            # 忽略Python优化编译文件

# Distribution / packaging
dist/                 # 忽略分发目录
build/                # 忽略构建目录
*.egg-info/           # 忽略egg信息目录

# Virtual environments
venv/                 # 忽略venv虚拟环境
env/                  # 忽略env虚拟环境
.env/                 # 忽略.env虚拟环境

# IDE settings
.vscode/              # 忽略VS Code设置
.idea/                # 忽略PyCharm设置

# Unit test / coverage reports
htmlcov/             # 忽略HTML覆盖率报告
.tox/                # 忽略tox测试环境
.nox/                # 忽略nox测试环境
.coverage            # 忽略覆盖率数据
.pytest_cache/       # 忽略pytest缓存

# mypy
.mypy_cache/         # 忽略mypy缓存
# Pyre type checker
.pyre/               # 忽略Pyre类型检查器缓存
# pytype static type analyzer
.pytype/             # 忽略pytype静态分析器缓存

# Ruff stuff
.ruff_cache/         # 忽略Ruff缓存
# Cursor
.cursorignore        # 忽略Cursor AI编辑器忽略文件
.cursorindexingignore # 忽略Cursor索引忽略文件

.DS_Store            # 忽略macOS系统文件

